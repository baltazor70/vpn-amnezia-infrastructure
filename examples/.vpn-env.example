# VPN Bot Environment Variables
# Скопируй этот файл в /root/.vpn-env и заполни своими значениями
# Этот файл НЕ должен коммититься в Git!

# Telegram Bot Token (получи у @BotFather)
export BOT_TOKEN="your_bot_token_here"

# Your Telegram Chat ID (узнай у @userinfobot)
export CHAT_ID="your_chat_id_here"

# Имя контейнера AmneziaWG
export CONTAINER_NAME="amnezia-awg2"

# Путь для хранения бэкапов
export BACKUP_DIR="/root/backups/vpn"

# Название сервера для уведомлений
export SERVER_NAME="🇳 VPN-Server"
